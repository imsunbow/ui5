<mvc:View controllerName="code1.cl5.root.p01.code1cl5rootp01.controller.StudentView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

        <Button text="Search" icon="sap-icon://search" press=".onSearch"/> 
        <Input id="iClass" width="7rem" placeholder="Class" showClearIcon="true"/>
        <Input id="iClnum" width="7rem" placeholder="ClNum" showClearIcon="true"/>

        <t:Table
            id="StudentList"
            visibleRowCount = "10"
            rows="{/StudentSet}" 
            selectionMode="Single"
            selectionBehavior="RowOnly"
            paste="onPaste"
            ariaLabelledBy="title">

            <t:columns>

                <!-- class -->
                <t:Column width="5rem">
                    <Label text="Class" />
                    <t:template>
                        <Text text="{Class}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- class num -->
                <t:Column width="5rem">
                    <Label text="ClNum" />
                    <t:template>
                        <Text text="{ClNum}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- Name -->
                <t:Column width="10rem">
                    <Label text="Name" />
                    <t:template>
                        <Text text="{Name}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- phone -->
                <t:Column width="10rem">
                    <Label text="Phone" />
                    <t:template>
                        <Text text="{Phone}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- Gender -->
                <t:Column width="5rem">
                    <Label text="Gender" />
                    <t:template>
                        <Text text="{Gender}" wrapping="false" />
                    </t:template>
                </t:Column>

            </t:columns>

        </t:Table>

    </Page>
</mvc:View>