<mvc:View controllerName="code1.cl5.cds02.code1cl5cds02.controller.ChartView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns="sap.suite.ui.microchart"
    >
    
    <m:Page id="page" title="{i18n>title}">

        <m:VBox width="30rem" height="25rem">
            <InteractiveDonutChart displayedSegments="8" segments="{ path: '/CountSet' }" >
                <segments>
                    <InteractiveDonutChartSegment label="{Carrid}" 
                                                  value="{Cnt}"
                                                  displayedValue="{Carrid}/{Cnt}"/>
                </segments>
            </InteractiveDonutChart>
        </m:VBox>

        <m:VBox width="30rem" height="25rem">
            <InteractiveLineChart displayedPoints= "8" points="{ path: '/CountSet' }"> 
                                        
                <points>
                    <InteractiveLineChartPoint value="{Cnt}" label="{Carrid}" displayedValue="{Carrid}/{Cnt}" />
                </points>

            </InteractiveLineChart>
        </m:VBox>

        <m:VBox width="30rem" height="25rem">
            <InteractiveBarChart displayedBars="8" bars= "{ path: '/CountSet' }">

                <bars>
                    <InteractiveBarChartBar label="{Carrid}" value="{Cnt}" displayedValue="{Carrid}/{Cnt}"/>
                </bars>
                
            </InteractiveBarChart>
        </m:VBox>

    </m:Page>
    

</mvc:View>