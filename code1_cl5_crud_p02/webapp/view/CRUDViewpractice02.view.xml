<mvc:View controllerName="code1.cl5.crud.p02.code1cl5crudp02.controller.CRUDViewpractice02"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <t:Table
        id="matList"
        rows="{/MatSet}"
        visibleRowCount="7"
        selectionMode="Single"
        selectionBehavior="RowOnly"
        paste="onPaste"
        ariaLabelledBy="title">

        <t:extension>

            <OverflowToolbar style="Clear">
                <!-- search -->
                <Button icon="sap-icon://search" text="Search" press="onSearch"/>
                <ToolbarSpacer width="2rem"/>
                <Input id="ISteel" placeholder="Steel" width="6rem" maxLength="10" showClearIcon="true"/>
                <Input id="IWerks" placeholder="Plant" width="6rem" maxLength="10" showClearIcon="true"/>                
            </OverflowToolbar>

        </t:extension>

        <t:columns>

            <t:Column width="10rem">
                <Label text="Steel" />
                <t:template>
                    <Text text="{Steel}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Plant" />
                <t:template>
                    <Text text="{Werks}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Industry" />
                <t:template>
                    <Text text="{IndustryKind}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Area" />
                <t:template>
                    <Text text="{Area}" wrapping="false" />
                </t:template>
            </t:Column>

            <!-- 단위필드 -->
            <t:Column width="10rem">
                 <Label text="Meins" />
                 <t:template>
                    <Text text="{
                          parts: [
                                    {path: 'Menge'}, 
                                    {path: 'Meins'}
                                 ],
                                    type: 'sap.ui.model.type.Unit',
                                    formatOptions: { 
                                        showMeasure: true 
                                    }
                    }" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Meins" />
                <t:template>
                    <Text text="{Meins}" wrapping="false" />
                </t:template>
            </t:Column>

            <!-- 통화필드 -->
            <t:Column width="10rem">
                <Label text="Waers" />
                <t:template>
                    <Text text="{ parts: [ {path: 'Dmbtr'}, {path: 'Waers'} ],
                                  type: 'sap.ui.model.type.Currency',
                                  formatOptions: { showMeasure: true } }" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Waers" />
                <t:template>
                    <Text text="{Waers}" wrapping="false" />
                </t:template>
            </t:Column>

        </t:columns>

    </t:Table>

    <OverflowToolbar style="Clear">
        <Label text="Material List" width="10rem"/>
        <ToolbarSpacer width="25rem"/>
        <Button icon="sap-icon://eraser" text="Clear" press="onClear" />
        <Button icon="sap-icon://display" text="Display" press="onDisplay"/>
        <Button icon="sap-icon://display" text="Read" press="onRead"/>
        <Button icon="sap-icon://create" text="Create" press="onCreate" />
        <Button icon="sap-icon://edit" text="Update" press="onUpdate" />
        <Button icon="sap-icon://delete" text="Delete" press="onDelete" />
    </OverflowToolbar>

    <f:SimpleForm id="inputForm" editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3" labelSpanM="3"
                  labelSpanS="12" adjustLabelSpan="false" emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0"
                  columnsXL="1" columnsL="1" columnsM="1" singleContainerFullSize="true" >

        <f:content>
            <Label text="Steel" />
            <Input id="Steel" width="6rem" maxLength="10"/>
            <Label text="Plant" />
            <Input id="Werks" width="10rem" maxLength="10"/>
            <Label text="Industry" />
            <Input id="IndustryKind" width="4rem" maxLength="4"/>
            <Label text="Area" />
            <Input id="Area" width="10rem" maxLength="10"/>
            <Label text="Menge" />
            <Input id="Menge" width="4rem" maxLength="10"/>
            <Label text="Meins" />
            <Input id="Meins" width="6rem" maxLength="9"/>
            <Label text="Dmbtr" />
            <Input id="Dmbtr" width="5rem" maxLength="10"/>
            <Label text="Waers" />
            <Input id="Waers" width="5rem" maxLength="10"/>
        </f:content>

    </f:SimpleForm>

    </Page>
</mvc:View>