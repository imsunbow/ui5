<mvc:View controllerName="code.cl5.srv02.codecl5srv02.controller.PriceView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <Panel width="50em">
            <viz:VizFrame id="idVizFrame" uiConfig="{applicationSet:'fiori'}"
            height='30em' width="30em" vizType='pie' vizProperties="{title:{visible:false}, plotArea:{dataLabel:{visible:true}, drawingEffect:'glossy'}}">

                    <!-- define dataset -->
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/PriceSet}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Carrid" value="{Carrid}" />
                                <viz.data:DimensionDefinition name="Connid" value="{Connid}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Payment" value="{=parseFloat(${Payment})}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>

                    <!-- define feeds -->
                    <viz:feeds>
                        <viz.feeds:FeedItem id='valueAxisFeed' uid="size" type="Measure"
                            values="Payment" />
                        <viz.feeds:FeedItem id='categoryAxisFeed' uid="color" type="Dimension"
                            values="Carrid,Connid" />
                    </viz:feeds>
                    
            </viz:VizFrame>
        </Panel>
    </Page>
</mvc:View>