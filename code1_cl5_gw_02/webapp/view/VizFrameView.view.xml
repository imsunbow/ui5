<mvc:View controllerName="code1.cl5.gw02.code1cl5gw02.controller.VizFrameView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <viz:VizFrame id="idVizFrame" uiConfig="{applicationSet:'fiori'}" height='100rem' 
                  width='50rem' vizType='bar' vizProperties="{title:{visible:false}}">

            <!-- Dataset 정의 -->
            <viz:dataset>
                <viz.data:FlattenedDataset data="{/SBOOK2Set}">

                    <!-- 차원 -->
                    <viz.data:dimensions>
                        <viz.data:DimensionDefinition name="Carrid" value="{Carrid}" />
                        <viz.data:DimensionDefinition name="Connid" value="{Connid}" />
                    </viz.data:dimensions>

                    <!-- 측정값 -->
                    <viz.data:measures>
                        <viz.data:MeasureDefinition name="Count" value="{Cnt}" />
                        <viz.data:MeasureDefinition name="Forcuram sum" value="{Forcuram}" />
                        <viz.data:MeasureDefinition name="Weight" value="{Luggweight}" />
                    </viz.data:measures>

                </viz.data:FlattenedDataset>
            </viz:dataset>

            <viz:feeds>
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Carrid,Connid" />
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Count,Forcuram sum,Weight" />
            </viz:feeds>

    </viz:VizFrame>

    </Page>
</mvc:View>