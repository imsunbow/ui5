<mvc:View controllerName="code1.cl5.cds02.p1.code1cl5cds02p1.controller.ChartView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.suite.ui.microchart"
    xmlns:m="sap.m">
    <m:Page id="page" title="{i18n>title}">

        <m:VBox width="30rem" height="25rem">
            <InteractiveBarChart displayedBars="10" bars= "{ path: '/SumSet', sorter: { path: 'Belnr', descending: true }}">

                <bars>
                    <InteractiveBarChartBar 
                        label="{Belnr}" 
                        value="{= parseFloat(${DmbtrSum})}" 
                        />
                </bars>
                
            </InteractiveBarChart>
        </m:VBox>

    </m:Page>
</mvc:View>