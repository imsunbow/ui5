<mvc:View controllerName="code1.cl5.cds01.code1cl5cds011.controller.SpfliView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

<t:Table 

            visibleRowCount="10"
            rows="{/SpfliSet}" 
            selectionMode="Single" 
            selectionBehavior="Row"
            paste="onPaste"
            ariaLabelledBy="title">

            <t:extension>
                <OverflowToolbar style="Clear">
                    <Title text="Schedule"/>
                </OverflowToolbar>
            </t:extension>

            <t:columns>

                <t:Column width="11rem">
                    <Label text="Airline" />
                    <t:template>
                        <Text text="{Carrid}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Connection" />
                    <t:template>
                        <Text text="{Connid}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Airport From" />
                    <t:template>
                        <Text text="{Airpfrom}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Airport To" />
                    <t:template>
                        <Text text="{Airpto}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Dep.Time" />
                    <t:template>
                        <Text text="{Deptime}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Arr.Time" />
                    <t:template>
                        <Text text="{Arrtime}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="8rem">
                    <Label text="Distance" />
                    <t:template>
                        <Text text="{
                            parts:[{path:'Distance'},{path:'Distid'}],
                            type: 'sap.ui.model.type.Unit',
                            formatOptions: {showMeasure: true }
                            }" wrapping="false" />
                    </t:template>
                </t:Column>
       
            </t:columns>	

        </t:Table>

        <t:Table 

            visibleRowCount="10"
            rows="{Scarr>/ScarrSet}" 
            selectionMode="Single" 
            selectionBehavior="Row"
            paste="onPaste"
            ariaLabelledBy="title">

            <t:extension>
                <OverflowToolbar style="Clear">
                    <Title id="title" text="Airline"/>
                </OverflowToolbar>
            </t:extension>

            <t:columns>

                <t:Column width="11rem">
                    <Label text="Airline" />
                    <t:template>
                        <Text text="{Scarr>Carrid}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Carrname" />
                    <t:template>
                        <Text text="{Scarr>Carrname}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Currcode" />
                    <t:template>
                        <Text text="{Scarr>Currcode}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="11rem">
                    <Label text="Url" />
                    <t:template>
                        <Text text="{Scarr>Url}" wrapping="false" />
                    </t:template>
                </t:Column>

            </t:columns>	

        </t:Table>

    </Page>
</mvc:View>