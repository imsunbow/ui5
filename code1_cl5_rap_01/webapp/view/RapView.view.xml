<mvc:View controllerName="code1cl5rap01.controller.RapView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <t:Table
            id="StudentList"
            visibleRowCount = "20"
            rows="{/StudentSet}" 
            selectionMode="Single"
            selectionBehavior="RowOnly"
            paste="onPaste"
            ariaLabelledBy="title">

            <t:columns>

                <!-- class -->
                <t:Column width="5rem">
                    <Label text="Class" />
                    <t:template>
                        <Text text="{Class}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- class num -->
                <t:Column width="5rem">
                    <Label text="ClNum" />
                    <t:template>
                        <Text text="{ClNum}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- Name -->
                <t:Column width="5rem">
                    <Label text="Name" />
                    <t:template>
                        <Text text="{Name}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- phone -->
                <t:Column width="5rem">
                    <Label text="Phone" />
                    <t:template>
                        <Text text="{Phone}" wrapping="false" />
                    </t:template>
                </t:Column>

                <!-- Gender -->
                <t:Column width="5rem">
                    <Label text="Gender" />
                    <t:template>
                        <Text text="{Gender}" wrapping="false" />
                    </t:template>
                </t:Column>

            </t:columns>


    </t:Table>

    </Page>
</mvc:View>