<mvc:View controllerName="code1.cl516.abap3.p1.code1cl5abap31st.controller.SearchView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <t:Table
        id="shipList"
        rows="{/ShipSet}"
        visibleRowCount="7"
        selectionMode="Single" 
        selectionBehavior="RowOnly"
        paste="onPaste"
        ariaLabelledBy="title">

        <t:extension>

            <!-- OverflowToolbar => 입력 필드들을 받을 공간 할당 및 ID 부여 -->
            <OverflowToolbar style="Clear">
                <Input id="ITknum" placeholder="Shipment No" width="8rem" maxLength="10" showClearIcon="true"/>
                <!-- search -->
                <Button icon="sap-icon://search" text="Search" press="onSearch"/>          
            </OverflowToolbar>

        </t:extension>

        <!-- column 할당 -->
        <t:columns>
            
            <t:Column width="8rem">
                <Label text="Shipment No" />
                <t:template>
                    <Text text="{Tknum}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="5rem">
                <Label text="Shipment Item" />
                <t:template>
                    <Text text="{Tpnum}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="7rem">
                <Label text="Delivery" />
                <t:template>
                    <Text text="{Vbeln}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="SD Doc.Category" />
                <t:template>
                    <Text text="{Vbtyp}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Shipment type" />
                <t:template>
                    <Text text="{Shtyp}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Container ID" />
                <t:template>
                    <Text text="{Signi}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Itinerary (ship.items)" />
                <t:template>
                    <Text text="{Tprfo}" wrapping="false" />
                </t:template>
            </t:Column>

            <!-- 단위필드 => 수량-단위 묶어서 표현 -->
            <t:Column width="8rem">
                <Label text="Scale Quantity" />
                <t:template>
                    <Text text="{
                                    parts:[{path:'Smeng'},{path:'Meins'}],
                                    type: 'sap.ui.model.type.Unit',
                                    formatOptions: {showMeasure: true }
                                }"  wrapping="false" />
                </t:template>
            </t:Column>

            <!-- 금액필드 => 금액-화폐단위 묶어서 표현 -->
            <t:Column width="10rem">
                <Label text="Net Value" />
                <t:template>
                    <Text text="{
                                    parts:[{path:'Netwr'},{path:'Waerk'}],
                                    type: 'sap.ui.model.type.Currency',
                                    formatOptions: {showMeasure: true }
                                }"  wrapping="false" />
                </t:template>
            </t:Column>

        </t:columns>

    </t:Table>

    </Page>
</mvc:View>