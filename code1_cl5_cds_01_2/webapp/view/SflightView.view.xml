<mvc:View controllerName="code1cl5cds02.code1cl5cds012.controller.SflightView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

<t:Table
            visibleRowCount="20"
            rows="{/SflightSet}" 
            cellClick="onClick" 
            selectionMode="Single" 
            selectionBehavior="RowOnly"
            paste="onPaste"
            ariaLabelledBy="title">

            <t:extension>
                <OverflowToolbar style="Clear">
                    <Title id="title" text="Schedule"/>
                </OverflowToolbar>
            </t:extension>

            <t:columns>

                <t:Column width="6rem">
                    <Label text="Carrid" />
                    <t:template>
                        <Text text="{Carrid}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="6rem">
                    <Label text="Connid" />
                    <t:template>
                        <Text text="{Connid}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="6rem">
                    <Label text="Fldate" />
                    <t:template>
                        <Text text="{Fldate}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="10rem">
                    <Label text="Price" />
                    <t:template>
                        <Text text="{
                            parts:[{path:'Price'},{path:'Currency'}],
                            type: 'sap.ui.model.type.Currency',
                            formatOptions: {showMeasure: true }
                            }" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="10rem">
                    <Label text="Paymentsum" />
                    <t:template>
                        <Text text="{
                            parts:[{path:'Paymentsum'},{path:'Currency'}],
                            type: 'sap.ui.model.type.Currency',
                            formatOptions: {showMeasure: true }
                            }" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="6rem">
                    <Label text="Currency" />
                    <t:template>
                        <Text text="{Currency}" wrapping="false" />
                    </t:template>
                </t:Column>

            </t:columns>
        </t:Table>


    </Page>
</mvc:View>