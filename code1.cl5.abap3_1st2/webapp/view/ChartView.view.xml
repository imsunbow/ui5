<mvc:View controllerName="code1.cl5.abap3.fst2.code1.cl5.abap31st2.controller.ChartView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <viz:VizFrame id="idVizFrame" uiConfig="{applicationSet:'fiori'}" 
                  height='30rem' width='70rem' vizType='column' vizProperties="{title:{visible:false}}" >

            <!-- Dataset 정의 -->
            <viz:dataset >
                <viz.data:FlattenedDataset data="{/ShipSet}" >

                    <!-- 차원 -->
                    <viz.data:dimensions>
                        <viz.data:DimensionDefinition name="Shipment Number" value="{Tknum}" />
                    </viz.data:dimensions>

                    <!-- 측정값 -->
                    <viz.data:measures>
                        <viz.data:MeasureDefinition name="Scale Quantity" value="{SmengSum}" />
                        <viz.data:MeasureDefinition name="Net Value" value="{NetwrSum}" />
                    </viz.data:measures>

                </viz.data:FlattenedDataset>
            </viz:dataset>

            <!-- 보여질 항목들. category -> 축 데이터, measure -> 계산값  -->
            <viz:feeds>
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Shipment Number" />
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Scale Quantity,Net Value" />
            </viz:feeds>

    </viz:VizFrame>


    </Page>
</mvc:View>