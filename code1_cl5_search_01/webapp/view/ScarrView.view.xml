<mvc:View controllerName="code1.cl5.search01.code1cl5search01.controller.ScarrView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <Button text="Search" icon="sap-icon://search" press=".onSearch"/> 
        <Input id="iCarrid" width="5rem" placeholder="Airline" showClearIcon="true"/>
        <Input id="iCurrcode" width="7rem" placeholder="Currency"/>

        <t:Table
            id="AirlineList"
            visibleRowCount = "20"
            rows="{/ScarrSet}" 
            selectionMode="Single"
            selectionBehavior="RowOnly"
            paste="onPaste"
            ariaLabelledBy="title">
            <t:extension>
                <OverflowToolbar style="Clear">
                    <Title text="Airline"/>
                </OverflowToolbar>
            </t:extension>
            <t:columns>
                <t:Column width="5rem">
                    <Label text="Airline" />
                    <t:template>
                        <Text text="{Carrid}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem"> 
                    <Label text="Airline Name" />
                    <t:template>
                        <Text text="{Carrname}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="6rem">
                    <Label text="Currency" />
                    <t:template>
                        <Text text="{Currcode}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="13rem">
                    <Label text="Home Page" />
                    <t:template>
                        <Text text="{Url}" wrapping="false" />
                    </t:template>
                </t:Column>
            </t:columns>
        </t:Table>

    </Page>
</mvc:View>