<mvc:View controllerName="code1.cl5.gw01.code1cl5gw01.controller.GridView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <t:Table
            visibleRowCount="13"
        
            rows="{/CoepSet}"
            cellClick="onClick" 
            selectionMode="Single" 
            selectionBehavior="RowSelector"
            paste="onPaste"
            ariaLabelledBy="title">

            <t:columns>

                <t:Column width="6rem">
                    <Label text="Kokrs" />
                    <t:template>
                        <Text text="{Kokrs}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="10rem">
                    <Label text="Belnr" />
                    <t:template>
                        <Text text="{Belnr}" wrapping="false" />
                    </t:template>
                 </t:Column>

                <t:Column width="6rem">
                    <Label text="Buzei" />
                    <t:template>
                        <Text text="{Buzei}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="6rem" sortProperty="Gjahr">
                    <Label text="Gjahr" />
                    <t:template>
                        <Text text="{Gjahr}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="6rem">
                    <Label text="Budat" />
                    <t:template>
                        <Text text="{Budat}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="12rem">
                    <Label text="Wkgbtr" />
                    <t:template>
                        <Text text="{parts:[{path:'Wkgbtr'},{path:'Twaer'}],
                            type: 'sap.ui.model.type.Currency',
                            formatOptions: {showMeasure: true }}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="6rem">
                    <Label text="Twaer" />
                    <t:template>
                        <Text text="{Twaer}" wrapping="false" />
                    </t:template>
                </t:Column>

            </t:columns>

    </t:Table>

    </Page>
</mvc:View>