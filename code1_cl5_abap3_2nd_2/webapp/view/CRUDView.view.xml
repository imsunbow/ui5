<mvc:View controllerName="code1.cl5.abap3.code1cl5abap32nd2.controller.CRUDView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

    <!-- table 속성 부여 -->
    <t:Table
        id="shipList"
        rows="{/ShipSet}"
        visibleRowCount="7"
        selectionMode="Single" 
        selectionBehavior="RowOnly"
        paste="onPaste"
        ariaLabelledBy="title">

        <t:extension>

            <!-- OverflowToolbar => 입력 필드를 받을 공간 할당 및 ID 부여 -->
            <OverflowToolbar style="Clear">
                <!-- input field -->
                <Label text= "배송 조회"/>
                <Input id="ITknum" placeholder="Shipment No" width="8rem" maxLength="10" showClearIcon="true"/>
                <ToolbarSpacer width="60rem"/>
                <!-- search -->
                <Button icon="sap-icon://search" text="Search" press="onSearch"/>
            </OverflowToolbar>

        </t:extension>

        <!-- column 할당 -->
        <t:columns>

            <t:Column width="8rem">
                <Label text="Shipment No" />
                <t:template>
                    <Text text="{Tknum}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="5rem">
                <Label text="Shipment Item" />
                <t:template>
                    <Text text="{Tpnum}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="7rem">
                <Label text="Delivery" />
                <t:template>
                    <Text text="{Vbeln}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="SD Doc.Category" />
                <t:template>
                    <Text text="{Vbtyp}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Shipment type" />
                <t:template>
                    <Text text="{Shtyp}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Container ID" />
                <t:template>
                    <Text text="{Signi}" wrapping="false" />
                </t:template>
            </t:Column>

            <t:Column width="10rem">
                <Label text="Itinerary (ship.items)" />
                <t:template>
                    <Text text="{Tprfo}" wrapping="false" />
                </t:template>
            </t:Column>

            <!-- 단위필드 => 수량-단위 묶어서 표현 -->
            <t:Column width="8rem">
                <Label text="Scale Quantity" />
                <t:template>
                    <Text text="{
                                    parts:[{path:'Smeng'},{path:'Meins'}],
                                    type: 'sap.ui.model.type.Unit',
                                    formatOptions: {showMeasure: true }
                                }"  wrapping="false" />
                </t:template>
            </t:Column>

            <!-- 금액필드 => 금액-화폐단위 묶어서 표현 -->
            <t:Column width="10rem">
                <Label text="Net Value" />
                <t:template>
                    <Text text="{
                                    parts:[{path:'Netwr'},{path:'Waerk'}],
                                    type: 'sap.ui.model.type.Currency',
                                    formatOptions: {showMeasure: true }
                                }"  wrapping="false" />
                </t:template>
            </t:Column>

        </t:columns>

    </t:Table>

    <OverflowToolbar style="Clear">
        <Label text="정보 입력" width="7rem"/>
        <!-- 빈공간 할당 -->
        <ToolbarSpacer width="40rem"/>
        <!-- 버튼 첨부 -->
        <Button icon="sap-icon://eraser" text="Clear" press="onClear" />
        <Button icon="sap-icon://display" text="Display" press="onDisplay"/>
        <Button icon="sap-icon://display" text="Read" press="onRead"/>
        <Button icon="sap-icon://edit" text="edit" press="onUpdate" />
        <Button icon="sap-icon://create" text="Create" press="onCreate" />
        <Button icon="sap-icon://delete" text="Delete" press="onDelete" />
    </OverflowToolbar>

    <!-- form 속성 할당 -->
    <f:SimpleForm id="inputForm" editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3" labelSpanM="3"
                  labelSpanS="12" adjustLabelSpan="false" emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0"
                  columnsXL="1" columnsL="1" columnsM="1" singleContainerFullSize="true" >

        <!-- form 데이터 및 라벨설정 -->
        <f:content>
            <Label text="Shipment No" />
            <Input id="Tknum" width="15rem" maxLength="10"/>
            <Label text="Shipment Item" />
            <Input id="Tpnum" width="15rem" maxLength="10"/>
            <Label text="Delivery" />
            <Input id="Vbeln" width="15rem" maxLength="10"/>
            <Label text="SD Doc.Category" />
            <Input id="Vbtyp" width="15rem" maxLength="10"/>
            <Label text="Shipment Type" />
            <Input id="Shtyp" width="15rem" maxLength="10"/>
            <Label text="Container ID" />
            <Input id="Signi" width="15rem" maxLength="10"/>
            <Label text="Itinery" />
            <Input id="Tprfo" width="15rem" maxLength="10"/>
            <Label text="Scale Quantity" />
            <Input id="Smeng" width="15rem" maxLength="10"/>
            <Label text="Unit" />
            <Input id="Meins" width="15rem" maxLength="10"/>
            <Label text="Net Value" />
            <Input id="Netwr" width="15rem" maxLength="10"/>
            <Label text="Currency" />
            <Input id="Waerk" width="15rem" maxLength="10"/>
        </f:content>
    
    </f:SimpleForm>

    </Page>
</mvc:View>