<mvc:View controllerName="code1.cl5.search02.code1cl5search02.controller.FlightView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">

        <Button text="Search" icon="sap-icon://search" press=".onSearch"/> 
        <Input id="iCarrid" width="4rem" placeholder="Airline" showClearIcon="true"/>
        <Input id="iConnid" width="6rem" placeholder="Connection" showClearIcon="true"/>
        <Input id="iFldate" width="6rem" placeholder="Flight date" showClearIcon="true"/>

        <t:Table
            id="FlightList"
            visibleRowCount = "20"
            rows="{/SflightSet}" 
            selectionMode="Single"
            selectionBehavior="RowOnly"
            paste="onPaste"
            ariaLabelledBy="title">

            <t:extension>
                <OverflowToolbar style="Clear">
                    <Title text="Filght Information"/>
                </OverflowToolbar>
            </t:extension>

            <t:columns>

                <t:Column width="5rem">
                    <Label text="Airline" />
                    <t:template>
                        <Text text="{Carrid}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="5rem">
                    <Label text="Connection" />
                    <t:template>
                        <Text text="{Connid}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="12rem">
                    <Label text="Flight date" />
                    <t:template>
                        <Text text="{Fldate}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="7rem">
                    <Label text="Price" />
                    <t:template>
                         <Text text="{
                            parts:[{path:'Price'},{path:'Currency'}],
                            type: 'sap.ui.model.type.Currency',
                            formatOptions: {showMeasure: true }
                            }" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="8rem">
                    <Label text="Total Price" />
                    <t:template>
                         <Text text="{
                            parts:[{path:'Paymentsum'},{path:'Currency'}],
                            type: 'sap.ui.model.type.Currency',
                            formatOptions: {showMeasure: true }
                            }" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column width="5rem">
                    <Label text="Plane type" />
                    <t:template>
                        <Text text="{Planetype}" wrapping="false" />
                    </t:template>
                </t:Column>

            </t:columns>

        </t:Table>


    </Page>
</mvc:View>