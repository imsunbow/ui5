<mvc:View controllerName="code1.cl516.split01.code1cl5splitp01.controller.SplitViewPractice01"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        
        <!-- set table properties -->
        <t:Table id="Bkpf" rows="{/BkpfSet}" selectionMode="Single"
                 visibleRowCount="10" selectionBehavior="RowOnly" paste="onPaste"  
                 cellClick="onBseg"   ariaLabelledBy="title">

                <t:columns>

                    <!-- Bukrs column -->
                    <t:Column width="10rem">
                        <Label text="Bukrs" />
                        <t:template>
                            <Text text="{Bukrs}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Belnr column -->
                    <t:Column width="10rem">
                        <Label text="Belnr" />
                        <t:template>
                            <Text text="{Belnr}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Gjahr column -->
                    <t:Column width="10rem">
                        <Label text="Gjahr" />
                        <t:template>
                            <Text text="{Gjahr}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Blart column -->
                    <t:Column width="10rem">
                        <Label text="Blart" />
                        <t:template>
                            <Text text="{Blart}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Budat column -->
                    <t:Column width="10rem">
                        <Label text="Budat" />
                        <t:template>
                            <Text text="{Budat}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Cputm column -->
                    <t:Column width="10rem">
                        <Label text="Cputm" />
                        <t:template>
                            <Text text="{Cputm}" wrapping="false" />
                        </t:template>
                    </t:Column>

                </t:columns>

        </t:Table>

        <!-- set table properties -->
        <t:Table id="Bseg" rows="{/BsegSet}" selectionMode="Single"
                 visibleRowCount="10" selectionBehavior="RowOnly"
                 paste="onPaste" ariaLabelledBy="title">

                <t:columns>

                    <!-- Bukrs column -->
                    <t:Column width="10rem">
                        <Label text="Bukrs" />
                        <t:template>
                            <Text text="{Bukrs}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Belnr column -->
                    <t:Column width="10rem">
                        <Label text="Belnr" />
                        <t:template>
                            <Text text="{Belnr}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Gjahr column -->
                    <t:Column width="10rem">
                        <Label text="Gjahr" />
                        <t:template>
                            <Text text="{Gjahr}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Buzei column -->
                    <t:Column width="10rem">
                        <Label text="Buzei" />
                        <t:template>
                            <Text text="{Buzei}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Bschl column -->
                    <t:Column width="10rem">
                        <Label text="Bschl" />
                        <t:template>
                            <Text text="{Bschl}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Shkzg column -->
                    <t:Column width="10rem">
                        <Label text="Shkzg" />
                        <t:template>
                            <Text text="{Shkzg}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Wrbtr column -->
                    <t:Column width="10rem">
                        <Label text="Wrbtr" />
                        <t:template>
                            <Text text="{
                                        parts:[{path:'Wrbtr'},{path:'Pswsl'}],
                                        type: 'sap.ui.model.type.Currency',
                                        formatOptions: {showMeasure: true }
                                        }" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Pswsl column -->
                    <t:Column width="10rem">
                        <Label text="Pswsl" />
                        <t:template>
                            <Text text="{Pswsl}" wrapping="false" />
                        </t:template>
                    </t:Column>

                </t:columns>
        </t:Table>
    </Page>
</mvc:View>