<mvc:View controllerName="code1.cl516.gw0009.code1cl5split01.controller.SplitView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns="sap.m"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
    <Page id="page" title="{i18n>title}">
        
        <!-- Bind Masterpages and Detail pages using Splitcontainer object -->
        <SplitContainer id="SplitContDemo" initialMaster="master" initialDetail="detail">
		                
        <masterPages>

            <!-- Set page properties -->
			<Page id="master" title="항공사 리스트" backgroundDesign= "Solid">
                <List headerText="Airline List" headerLevel="H2" items="{ path: '/ScarrSet' }" >
                    <StandardListItem title="{Carrid}" description="{Carrname}" icon="sap-icon://flight" 
                                      type="Navigation" press=".onSpfli"/>
                </List>
            </Page>     
		</masterPages>

        <detailPages>
            
            <!-- Set page properties -->
            <Page id="detail" title="Detail page" backgroundDesign= "Solid">

            <!-- Set table properties -->
            <t:Table id="Spfli" rows="{/SpfliSet}" selectionMode="Single" visibleRowCount="5"
                     selectionBehavior="RowOnly"   paste="onPaste"        cellClick="onSflight"
                     ariaLabelledBy="title">

                <t:columns>

                    <!-- Airline Column -->
                    <t:Column width="5rem">
                        <Label text="Airline" />
                        <t:template>
                            <Text text="{Carrid}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Flight Number Column -->
                    <t:Column width="7rem">
                        <Label text="Flight Number" />
                        <t:template>
                            <Text text="{Connid}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Airport From Column -->
                    <t:Column width="7rem">
                        <Label text="Airport from" />
                        <t:template>
                            <Text text="{Airpfrom}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Airport to Column -->
                    <t:Column width="7rem">
                        <Label text="Airport To" />
                        <t:template>
                            <Text text="{Airpto}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Departure time Column -->
                    <t:Column width="7rem">
                        <Label text="Departure time" />
                        <t:template>
                            <Text text="{Deptime}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Arrival time Column -->
                    <t:Column width="7rem">
                        <Label text="Arrival time" />
                        <t:template>
                            <Text text="{Arrtime}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- Distance Column (Unit Column) -->
                    <t:Column width="7rem">
                        <Label text="Distance" />
                        <t:template>
                            <Text text="{
                                parts:[{path:'Distance'},{path:'Distid'}],
                                type: 'sap.ui.model.type.Unit',
                                formatOptions: {showMeasure: true }
                                }" wrapping="false" />
                        </t:template>
                    </t:Column>

                </t:columns>

            </t:Table>

            <!-- set table properties -->
            <t:Table id="Sflight" rows="{/SflightSet}" selectionMode="Single" visibleRowCount="5"
                     selectionBehavior="RowOnly" paste="onPaste" cellClick="onSbook"
                     ariaLabelledBy="title">

                    <t:columns>

                        <!-- Airline Column -->
                        <t:Column width="5rem">
                            <Label text="Airline" />
                            <t:template>
                                <Text text="{Carrid}" wrapping="false" />
                            </t:template>
                        </t:Column>

                        <!-- Flight Number Column -->
                        <t:Column width="7rem">
                            <Label text="Flight Number" />
                            <t:template>
                                <Text text="{Connid}" wrapping="false" />
                            </t:template>
                        </t:Column>

                        <!-- Flight Date Column -->
                        <t:Column width="7rem">
                            <Label text="Flight Date" />
                            <t:template>
                                <Text text="{Fldate}" wrapping="false" />
                            </t:template>
                        </t:Column>

                        <!-- Planetype Column -->
                        <t:Column width="7rem">
                            <Label text="Plane Type" />
                            <t:template>
                                <Text text="{Planetype}" wrapping="false" />
                            </t:template>
                        </t:Column>

                        <!-- Price Column (Currency Column)-->
                        <t:Column width="8rem">
                            <Label text="Price" />
                            <t:template>
                                <Text text="{
                                                parts:[{path:'Price'},{path:'Currency'}],
                                                type: 'sap.ui.model.type.Currency',
                                                formatOptions: {showMeasure: true }
                                            }"  wrapping="false" />
                            </t:template>
                        </t:Column>

                        <!-- Total Price Column (Currency Column)-->
                        <t:Column width="10rem">
                            <Label text="Total Price" />
                            <t:template>
                                <Text text="{
                                    parts:[{path:'Paymentsum'},{path:'Currency'}],
                                    type: 'sap.ui.model.type.Currency',
                                    formatOptions: {showMeasure: true }
                                    }" wrapping="false" />
                            </t:template>
                        </t:Column>

                    </t:columns>

            </t:Table>

                <!-- set flexbox properties -->
                <FlexBox width="860px" height="250px" >
                    
                    <!-- set vizframe properties -->
                    <viz:VizFrame id="vizChartLine" uiConfig="{applicationSet:'fiori'}"
                                  vizProperties="{
                                                   title:{text:'Booking Total', visible:false},  
                                                   plotarea: {drawingEffect: 'glossy'},
                                                   legend:{drawingEffect: 'glossy'}
                                                  }"
                                  width="860px" height='250px' vizType='line'>

                    <viz:dataset>

                        <!-- Set FlattenedDataset properties -->
                        <viz.data:FlattenedDataset data="{/SbookSet}">

                            <!-- bind dimensions -->
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Airline"
                                        value="{Carrid}" />
                                <viz.data:DimensionDefinition name="Flight Number"
                                        value="{Connid}" />
                                <viz.data:DimensionDefinition name="Flight Date"
                                        value="{Fldate}" />
                                <viz.data:DimensionDefinition name="Agency"
                                        value="{Agencynum}" />
                            </viz.data:dimensions>

                            <!-- bind Measures -->
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Booking Total"
                                    value="{Cnt}" />
                                <viz.data:MeasureDefinition name="Weight Total"
                                    value="{Luggweight}" />
                                <viz.data:MeasureDefinition name="Price Total"
                                    value="{Forcuram}" />
                            </viz.data:measures>

                        </viz.data:FlattenedDataset>

                    </viz:dataset>

                    <viz:feeds>

                        <!-- viz => Set Dimension . using this raises 50053 error(incomplete binding) for the first time -->
                        <!-- it disappears when vizframe object is bounded tho. -->

                        <!-- <viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
                            values="Airline" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
                            values="Flight Number" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
                            values="Flight Date" /> -->
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
                            values="Agency" />

                        <!-- viz => Set value using Measure type  -->
                        <viz.feeds:FeedItem id='valueAxisFeed1' uid="valueAxis" type="Measure"
                            values="Booking Total" />
                        <viz.feeds:FeedItem id='valueAxisFeed2' uid="valueAxis" type="Measure"
                            values="Weight Total" />
                        <viz.feeds:FeedItem id='valueAxisFeed3' uid="valueAxis" type="Measure"
                            values="Price Total" />

                    </viz:feeds>

                    <!-- Set Popover dependents -->
                    <viz:dependents>
                        <viz:Popover id="idPopOver"></viz:Popover>
                    </viz:dependents>

                    </viz:VizFrame>
                </FlexBox>
                    
            </Page>
        </detailPages>

    </SplitContainer>

    </Page>

</mvc:View>