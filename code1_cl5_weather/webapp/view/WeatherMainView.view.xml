<mvc:View controllerName="code1.cl5.weather.code1cl5weather.controller.WeatherMainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <Page id="page" title="{i18n>title}">
        <VBox alignItems="Center" justifyContent="Center" width="100%" height="100%">
            <Title text="🏙️ Select a city to view the Weather"  titleStyle="H1" textAlign="Center" class="sapUiMediumMarginBottom" />

            <!-- 🌍 지도 영역 -->
            <HBox justifyContent="Center" alignItems="Center" width="100%" height="auto">
                <Image id="mapImg" src="/Img/mapImg.png" width="60%" />
            </HBox>
        </VBox>
    </Page>
</mvc:View>