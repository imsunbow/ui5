<mvc:View
    controllerName="code1.cl5.weather.code1cl5weather.controller.DetailView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns="sap.m">

    <Page id="seoulPage" title="{i18n>title}">
        <VBox>
          <VBox width="100%" alignItems="Center">
                <!-- 오른쪽 상단 메인 버튼 -->
                <HBox width="100%" justifyContent="End">
                    <Button text="Back to Main" press="goMain" />
                </HBox>

                <!-- 제목 -->
                <Title text="🌤️ {regionModel>/region} Weather" titleStyle="H2" textAlign="Center" />

                <!-- 날짜 범위 검색 (date picker class)-->
                <HBox justifyContent="Center" class="sapUiTinyMarginBottom" >
                    <DatePicker id="sDate" 
                                value="{
                                            'path':'/valueSDate',
                                            'type':'sap.ui.model.type.Date',
                                            'formatOptions': {
                                                                'pattern': 'yyyy-MM-dd'
                                                            }
                                        }"
                                change="onSearch"
                    />

                    <!-- ~ 표시 -->
                    <Text text="~" class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />  


                    
                    <DatePicker id="eDate" 
                                value="{
                                            'path':'/valueEDate',
                                            'type':'sap.ui.model.type.Date',
                                            'formatOptions': {
                                                                'pattern': 'yyyy-MM-dd'
                                                            }
                                        }"
                                change="onSearch"
                    />

                    <!-- onClickBtn function 실행 및 매개변수 전달 -->
                    <Button text="Today" press="onClickBtn('1')" />
                    <Button text="Week" press="onClickBtn('7')"  />
                    <Button text="Month" press="onClickBtn('31')" />
                </HBox>
            </VBox>

            <!-- 테이블 + 차트 -->
            <HBox justifyContent="SpaceBetween">

                <!-- 왼쪽: 테이블 영역 -->
                <VBox width="25%">
                    <!-- 테이블 -->
                    <t:Table
                        id="Seoul"
                        rows="{/WeatherSet}"
                        selectionMode="Single"
                        selectionBehavior="RowOnly"
                        visibleRowCount="12"
                        ariaLabelledBy="title"
                        width="100%">
                        <t:columns>
                            <t:Column width="6rem">
                                <Label text="Date" />
                                <t:template><Text text="{date}" /></t:template>
                            </t:Column>
                            <t:Column width="6rem">
                                <Label text="MaxTemp" />
                                <t:template><Text text="{max_temp}°C" /></t:template>
                            </t:Column>
                            <t:Column width="6rem">
                                <Label text="MinTemp" />
                                <t:template><Text text="{min_temp}°C" /></t:template>
                            </t:Column>
                        </t:columns>
                    </t:Table>
                </VBox>

                <!-- 오른쪽: 차트 -->
                <VBox width="74%" height="100%">
                    <viz:VizFrame 
                        id="idVizFrame" 
                        uiConfig="{applicationSet:'fiori'}" 
                        height="27rem" 
                        width="100%" 
                        vizType="line" 
                        vizProperties="{
                            'title': { 'text': 'Temperature Trend', 'visible': true },
                            'plotArea': { 'dataLabel': { 'visible': true } },
                            'legend': { 'visible': true }
                        }">
                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{/WeatherSet}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition name="Date" value="{date}"/>
                                </viz.data:dimensions>
                                <viz.data:measures>
                                    <viz.data:MeasureDefinition name="MaxTemp" value="{max_temp}"/>
                                    <viz.data:MeasureDefinition name="MinTemp" value="{min_temp}"/>
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>
                        <viz:feeds>
                            <viz.feeds:FeedItem id="categoryAxisFeed" uid="categoryAxis" type="Dimension" values="Date" />
                            <viz.feeds:FeedItem id="valueAxisFeed" uid="valueAxis" type="Measure" values="MaxTemp,MinTemp"/>
                        </viz:feeds>
                    </viz:VizFrame>
                </VBox>

            </HBox>
        </VBox>
    </Page>
</mvc:View>